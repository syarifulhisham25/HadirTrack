<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selfie Check-In"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2D2363" />

                <TextView
                    android:id="@+id/sessionInfoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Take a selfie to complete attendance"
                    android:textSize="14sp"
                    android:textColor="#666666" />

            </LinearLayout>
        </LinearLayout>

        <!-- Selfie Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="3dp"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selfie Verification"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D2363"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capture your face clearly before submitting attendance."
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="14dp" />

            <ImageView
                android:id="@+id/selfieImageView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:scaleType="centerCrop"
                android:background="#E7DEFF"
                android:layout_marginBottom="16dp"
                android:contentDescription="Selfie Preview" />

            <Button
                android:id="@+id/takeSelfieButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Take Selfie"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/submitAttendanceButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Submit Attendance"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:enabled="false"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/backButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Back"
                android:textColor="#2D2363"
                android:textStyle="bold"
                android:background="@drawable/bg_button_secondary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>