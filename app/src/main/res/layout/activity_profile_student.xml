<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_student_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="My Profile"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1B4332" />

                <TextView
                    android:id="@+id/roleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Role"
                    android:textSize="14sp"
                    android:textColor="#666666" />

            </LinearLayout>
        </LinearLayout>

        <!-- Profile Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="3dp"
            android:padding="18dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1B4332"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update your personal details below."
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Full Name"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapWords"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:enabled="false"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#666666"
                android:textColorHint="#999999"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/studentIdInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Student ID / Matric Number"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/staffIdInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Staff ID"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapCharacters" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/updateProfileButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Update Profile"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_student_primary"
            android:layout_marginBottom="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Back"
            android:textColor="#2D2363"
            android:textStyle="bold"
            android:background="@drawable/bg_student_secondary"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>