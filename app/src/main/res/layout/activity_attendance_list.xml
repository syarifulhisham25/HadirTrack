<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F6FF">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Attendance List"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#2D2363"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submitted attendance records"
        android:textSize="16sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/totalPresentText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Present: 0"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#2D2363"
        android:layout_marginBottom="16dp" />

    <ListView
        android:id="@+id/attendanceListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp" />

    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        android:padding="12dp"
        android:layout_marginTop="12dp" />

</LinearLayout>