<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Session"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#2D2363"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/courseInfoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Course info"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/sessionTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Session Title e.g. Week 5 Lecture"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/locationNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Location Name e.g. Faculty of Computer and Mathematical Sciences"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/roomNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Room Name e.g. BK15"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/useCurrentLocationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use My Current Location"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/pickLocationMapButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick Location on Map"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/latitudeInput"
            android:enabled="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Latitude e.g. 3.0738"
            android:inputType="numberDecimal|numberSigned"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/longitudeInput"
            android:enabled="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Longitude e.g. 101.5183"
            android:inputType="numberDecimal|numberSigned"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/radiusInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Radius Meter e.g. 50"
            android:inputType="number"
            android:padding="14dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp" />

        <!-- Start Date & Time Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Date &amp; Time"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2D2363"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/startDateTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not selected"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/selectStartDateButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Date"
                android:padding="12dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/selectStartTimeButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Time"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Hidden TextViews to keep Java IDs compatible -->
        <TextView
            android:id="@+id/startDateText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/startTimeText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />


        <!-- End Date & Time Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="End Date &amp; Time"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2D2363"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/endDateTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Not selected"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/selectEndDateButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Date"
                android:padding="12dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/selectEndTimeButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Time"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Hidden TextViews to keep Java IDs compatible -->
        <TextView
            android:id="@+id/endDateText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/endTimeText"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveSessionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Session"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Back"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>