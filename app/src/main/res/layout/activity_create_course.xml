<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="22dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create Course"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#2D2363" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add course details for your class"
                    android:textSize="14sp"
                    android:textColor="#666666" />

            </LinearLayout>
        </LinearLayout>

        <!-- Course Details Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:elevation="3dp"
            android:padding="18dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Course Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2D2363"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This information will be shown to students enrolled in the course."
                android:textSize="14sp"
                android:textColor="#666666"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/courseCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Course Code e.g. ICT602"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/courseNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Course Name"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapWords"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/groupNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Group Name e.g. CDCS2405A"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/semesterInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Semester e.g. March 2026"
                android:padding="14dp"
                android:background="@drawable/bg_input"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"
                android:inputType="textCapWords" />

        </LinearLayout>

        <Button
            android:id="@+id/saveCourseButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Course"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:layout_marginBottom="12dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Back"
            android:textColor="#2D2363"
            android:textStyle="bold"
            android:background="@drawable/bg_button_secondary"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>